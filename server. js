const express = require('express');
const mongoose = require('mongoose');
const cors = require('cors');
require('dotenv').config();

const app = express();
app.use(cors());
app.use(express.json());

// Connexion MongoDB
mongoose.connect(process.env.MONGODB_URI)
  .then(() => console.log('✅ MongoDB connecté'))
  .catch(err => console.log('❌ Erreur MongoDB:', err));

// Modèles
const UserSchema = new mongoose.Schema({
  phone: { type: String, unique: true, required: true },
  name: String,
  rating: { type: Number, default: 0 },
  totalExchanges: { type: Number, default: 0 },
  createdAt: { type: Date, default: Date.now }
});

const ExchangeSchema = new mongoose.Schema({
  userId: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
  userName: String,
  userPhone: String,
  fromNetwork: String,
  toNetwork: String,
  amount: Number,
  status: { type: String, enum: ['active', 'completed', 'cancelled'], default: 'active' },
  createdAt: { type: Date, default: Date.now }
});

const User = mongoose.model('User', UserSchema);
const Exchange = mongoose.model('Exchange', ExchangeSchema);

// Routes API

// Health check
app.get('/', (req, res) => {
  res.json({ message: 'SwapCash API is running!' });
});

// Créer un compte
app.post('/api/register', async (req, res) => {
  try {
    const { phone, name } = req.body;
    let user = await User.findOne({ phone });
    if (user) return res.json({ user, exists: true });
    
    user = new User({ phone, name });
    await user.save();
    res.json({ user, exists: false });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Publier un échange
app.post('/api/exchanges', async (req, res) => {
  try {
    const { userId, userName, userPhone, fromNetwork, toNetwork, amount } = req.body;
    const exchange = new Exchange({
      userId, userName, userPhone, fromNetwork, toNetwork, amount
    });
    await exchange.save();
    res.json(exchange);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Lister les échanges actifs
app.get('/api/exchanges', async (req, res) => {
  try {
    const { from, to } = req.query;
    let query = { status: 'active' };
    if (from) query.fromNetwork = from;
    if (to) query.toNetwork = to;
    
    const exchanges = await Exchange.find(query)
      .sort({ createdAt: -1 })
      .limit(50);
    res.json(exchanges);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Marquer comme terminé
app.patch('/api/exchanges/:id', async (req, res) => {
  try {
    const exchange = await Exchange.findByIdAndUpdate(
      req.params.id,
      { status: req.body.status },
      { new: true }
    );
    res.json(exchange);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Supprimer un échange
app.delete('/api/exchanges/:id', async (req, res) => {
  try {
    await Exchange.findByIdAndDelete(req.params.id);
    res.json({ message: 'Supprimé' });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log(`🚀 SwapCash API démarrée sur le port ${PORT}`);
});
